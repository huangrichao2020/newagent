# Bailian
NEWAGENT_BAILIAN_API_KEY=your_bailian_api_key
NEWAGENT_BAILIAN_PLANNER_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
NEWAGENT_BAILIAN_EXECUTION_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
NEWAGENT_BAILIAN_SUMMARIZATION_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# Feishu
NEWAGENT_FEISHU_APP_ID=cli_xxx
NEWAGENT_FEISHU_APP_SECRET=your_feishu_app_secret
NEWAGENT_FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key
NEWAGENT_FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token
NEWAGENT_FEISHU_BOT_NAME=阿里云

# Runtime
NEWAGENT_STORAGE_ROOT=/root/newagent/storage
NEWAGENT_SCRAPLING_BASE_URL=http://127.0.0.1:7771
NEWAGENT_DISABLE_CODEX=true
